# ─── Azure VM IPs (private, within Azure VNet 10.0.1.0/24) ───────────────────
# Update these after `terraform output` gives you the private IPs
NODE_IPS=10.0.1.11,10.0.1.12,10.0.1.13

# ─── SSH credentials ──────────────────────────────────────────────────────────
# Path to SSH private key — in production inject from Azure Key Vault
CIS_SSH_KEY=~/.ssh/cis_key
CIS_SSH_USER=cassandra

# ─── Cassandra credentials (set after hardening) ─────────────────────────────
CIS_ADMIN_USER=cis_admin
CIS_ADMIN_PASS=changeme
