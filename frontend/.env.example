# ─── Azure backend URL ────────────────────────────────────────────────────────
# Replace <AZURE_VM_PUBLIC_IP> with output from `terraform output backend_public_ip`
VITE_API_URL=http://<AZURE_VM_PUBLIC_IP>:8000

# ─── Grafana (running on same VM as backend, or Azure Container Instance) ─────
VITE_GRAFANA_URL=http://<AZURE_VM_PUBLIC_IP>:3001
